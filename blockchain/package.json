{
  "name": "bloodlink-blockchain",
  "version": "1.0.0",
  "description": "BloodLink Smart Contracts — ERC-20 BDC Token + Soulbound NFT + Registry",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:coverage": "hardhat coverage",
    "deploy:local": "hardhat run scripts/deploy.js --network localhost",
    "deploy:sepolia": "hardhat run scripts/deploy.js --network sepolia",
    "deploy:ignition:local": "hardhat ignition deploy ./ignition/modules/BloodLink.js --network localhost",
    "deploy:ignition:sepolia": "hardhat ignition deploy ./ignition/modules/BloodLink.js --network sepolia",
    "verify": "hardhat run scripts/verify.js --network sepolia",
    "node": "hardhat node",
    "export-abi": "node scripts/exportABI.js",
    "gas-report": "REPORT_GAS=true hardhat test"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ignition": "^0.15.0",
    "@nomicfoundation/hardhat-ignition-ethers": "^0.15.0",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "dotenv": "^16.4.5",
    "hardhat": "^2.22.0",
    "hardhat-gas-reporter": "^1.0.8",
    "solidity-coverage": "^0.8.12"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^4.9.6"
  }
}
